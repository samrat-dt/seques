# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=groq        # anthropic | groq | google

ANTHROPIC_API_KEY=your_key_here   # https://console.anthropic.com/settings/keys
GROQ_API_KEY=your_key_here        # https://console.groq.com/keys  (free tier)
GOOGLE_API_KEY=your_key_here      # https://aistudio.google.com/apikey  (free tier)

# ── Analytics ─────────────────────────────────────────────────────────────────
# Mixpanel → Settings → Project Settings → Project Token
MIXPANEL_TOKEN=your_mixpanel_token_here
MIXPANEL_API_SECRET=your_mixpanel_api_secret_here

# ── Persistence (Phase 2) ─────────────────────────────────────────────────────
# Supabase → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=development         # development | staging | production
APP_VERSION=1.0.0
AUDIT_LOG_PATH=audit.log        # path to append-only audit log file

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30        # max mutating requests per IP per minute
